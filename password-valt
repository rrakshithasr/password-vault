import json
import os
import random
import string
import getpass

FILE_NAME = "passwords.json"


class PasswordVault:
    def __init__(self):
        self.data = {}
        self.load_data()

    def load_data(self):
        if os.path.exists(FILE_NAME):
            with open(FILE_NAME, "r") as file:
                try:
                    self.data = json.load(file)
                except json.JSONDecodeError:
                    self.data = {}

    def save_data(self):
        with open(FILE_NAME, "w") as file:
            json.dump(self.data, file, indent=4)

    def add_password(self):
        website = input("Enter Website: ").strip()

        if website in self.data:
            print("Website already exists!")
            return

        username = input("Enter Username: ")
        password = getpass.getpass("Enter Password: ")

        self.data[website] = {
            "username": username,
            "password": password
        }

        self.save_data()
        print("Password saved successfully.")

    def view_passwords(self):
        if not self.data:
            print("No passwords saved.")
            return

        print("\nSaved Accounts")
        print("-" * 40)

        for website, details in self.data.items():
            print(f"Website : {website}")
            print(f"Username: {details['username']}")
            print(f"Password: {details['password']}")
            print("-" * 40)

    def search_password(self):
        website = input("Enter Website: ").strip()

        if website in self.data:
            print("\nAccount Found")
            print("Username:", self.data[website]["username"])
            print("Password:", self.data[website]["password"])
        else:
            print("Website not found.")

    def update_password(self):
        website = input("Enter Website: ").strip()

        if website in self.data:
            new_password = getpass.getpass("Enter New Password: ")
            self.data[website]["password"] = new_password
            self.save_data()
            print("Password updated successfully.")
        else:
            print("Website not found.")

    def delete_password(self):
        website = input("Enter Website: ").strip()

        if website in self.data:
            del self.data[website]
            self.save_data()
            print("Password deleted successfully.")
        else:
            print("Website not found.")

    def generate_password(self):
        length = int(input("Enter Password Length: "))

        characters = (
            string.ascii_letters +
            string.digits +
            string.punctuation
        )

        password = "".join(random.choice(characters) for _ in range(length))

        print("\nGenerated Password:")
        print(password)


vault = PasswordVault()

while True:
    print("\n===== PASSWORD VAULT =====")
    print("1. Add Password")
    print("2. View Passwords")
    print("3. Search Password")
    print("4. Update Password")
    print("5. Delete Password")
    print("6. Generate Password")
    print("7. Exit")

    choice = input("Enter your choice: ")

    if choice == "1":
        vault.add_password()

    elif choice == "2":
        vault.view_passwords()

    elif choice == "3":
        vault.search_password()

    elif choice == "4":
        vault.update_password()

    elif choice == "5":
        vault.delete_password()

    elif choice == "6":
        vault.generate_password()

    elif choice == "7":
        print("Thank you for using Password Vault!")
        break

    else:
        print("Invalid choice. Please try again.")